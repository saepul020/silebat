# Salin nilai berikut ke Vercel Project Settings > Environment Variables
# Jangan unggah file ini sebagai .env production berisi credential asli.

SECRET_KEY=change-this-production-secret-key
DEBUG=False

ALLOWED_HOSTS=silebat-cujz.vercel.app
CSRF_TRUSTED_ORIGINS=https://silebat-cujz.vercel.app
PUBLIC_BASE_URL=https://silebat-cujz.vercel.app

# Gunakan salah satu koneksi database eksternal.
# Contoh Neon/Supabase/Railway/Vercel Postgres:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

DASHBOARD_TV_SLUG=lab-tv-realtime-silebat-7q4m2x9v
